<section class="flex flex-col items-center">
  <h1><%= gettext("Welcome to %{name}!", name: "DerpyCoder") %></h1>
  <p>Peace of mind from prototype to production</p>

  <%= live_patch("Photos", to: Routes.photo_index_path(@socket, :index)) %>

  <%= link("User Dashboard", to: Routes.user_dashboard_path(@socket, :index)) %>
  <%= link("Admin Dashboard", to: Routes.admin_dashboard_path(@socket, :index)) %>
</section>
