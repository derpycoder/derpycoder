<div class="absolute -top-12 flex justify-center w-full">
  <button class="rounded-tl-lg rounded-bl-lg p-2 bg-slate-100 m-0">
    <HeroIcons.Solid.eye class="h-6 w-6 text-gray-500" />
  </button>
  <button
    phx-click="inspect-source"
    phx-value-file={@file}
    class="rounded-tr-lg rounded-br-lg p-2 bg-slate-100 m-0 border-l border-slate-200"
    phx-target={@myself}
  >
    <HeroIcons.Solid.code class="h-6 w-6 text-gray-500" />
  </button>
</div>
