PORT=4000
SECRET_KEY_BASE=yGgjzKC+PhpuL5VRIYcLuz6gYWucxywnoBq7xV1buAaPnLRk/HltcxR2R95jwapc

# Cockroach DB Config
USER_NAME=derp
USER_PASSWORD=wubalubadubdub
HOST_NAME=localhost
DATABASE_NAME=derpy_coder_dev
DATABASE_PORT=26257
ENABLE_SSL=true
CA_CERT_FILE=certs/cockroach_db/ca.crt
KEY_FILE=certs/cockroach_db/client.derp.key
